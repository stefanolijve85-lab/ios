# ---- Glass Bridge server environment ----
# Copy to .env for local development. All values below are safe local defaults
# EXCEPT the secrets, which you MUST change for any public deployment.

# HTTP port
PORT=4000
NODE_ENV=development

# Auth — generate a long random string for production (e.g. `openssl rand -hex 32`)
JWT_SECRET=dev-insecure-secret-change-me
JWT_EXPIRES_IN=7d

# CORS: comma-separated origins, or * for any (dev only)
CORS_ORIGIN=*

# Database. LEAVE UNSET to use the zero-config in-memory store (data resets on
# restart). Set it to enable PostgreSQL persistence.
# DATABASE_URL=postgres://glassbridge:glassbridge@localhost:5432/glassbridge
# PGSSL=false   # set false for local Postgres; true (default) for managed hosts

# Economy
STARTING_BALANCE=1000
MIN_BET=0.1
MAX_BET=1000
MAX_PAYOUT=100000
HOUSE_EDGE=0.02

# Seeded admin account (created by `npm run seed`)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-now
ADMIN_EMAIL=admin@example.com
