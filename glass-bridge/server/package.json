{
  "name": "glass-bridge-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Glass Bridge — authoritative game server (Express + Socket.IO + PostgreSQL).",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "migrate": "tsx src/db/migrate.ts",
    "seed": "tsx src/db/seed.ts",
    "migrate:prod": "node dist/db/migrate.js",
    "seed:prod": "node dist/db/seed.js",
    "verify": "node verify-fairness.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "bcryptjs": "2.4.3",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "4.21.2",
    "express-rate-limit": "7.4.1",
    "helmet": "8.0.0",
    "jsonwebtoken": "9.0.2",
    "pg": "8.13.1",
    "socket.io": "4.8.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/jsonwebtoken": "9.0.7",
    "@types/node": "20.14.10",
    "@types/pg": "8.11.10",
    "tsx": "4.19.2",
    "typescript": "5.5.3",
    "vitest": "2.1.8"
  }
}
