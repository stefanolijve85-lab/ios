# --- Core ---
ENV=development
LOG_LEVEL=INFO
SECRET_KEY=change-me-please-32-bytes-minimum
JWT_ALG=HS256
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=2592000

# --- Database ---
DATABASE_URL=postgresql+psycopg://trustline:trustline@db:5432/trustline

# --- Redis / queue ---
REDIS_URL=redis://redis:6379/0

# --- Storage (S3 or compatible) ---
S3_ENDPOINT=
S3_BUCKET=trustline-dev
S3_REGION=eu-west-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- OCR provider (azure | google | mock) ---
OCR_PROVIDER=mock
AZURE_DOCINTEL_ENDPOINT=
AZURE_DOCINTEL_KEY=
GOOGLE_DOCAI_PROCESSOR=

# --- LLM provider (anthropic | openai | mock) ---
LLM_PROVIDER=mock
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- VAT / registry ---
VIES_BASE=https://ec.europa.eu/taxation_customs/vies/services/checkVatService
KVK_API_KEY=

# --- CORS ---
CORS_ORIGINS=http://localhost:3000
