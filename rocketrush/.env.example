# Liftoff X — environment.
# Copy to `.env.local` and fill in to enable Supabase accounts.
# Leave blank to run in guest mode (no accounts, balance kept locally).

# --- Client (Next.js, PUBLIC — safe to expose). Enables the account UI. ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# --- Game server (PRIVATE — service role. NEVER expose to the browser). ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
